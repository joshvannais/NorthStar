# Retell AI API
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=your_retell_agent_id_here

# Twilio (phone number)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE_NUMBER=+1your_twilio_number_here

# Google Sheets (for lead storage)
GOOGLE_SHEETS_PRIVATE_KEY=your_google_private_key_here
GOOGLE_SHEETS_CLIENT_EMAIL=your_service_account_email_here
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Email notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# SMS notifications (via Twilio)
NOTIFICATION_PHONE=+1contractor_phone_here
NOTIFICATION_EMAIL=contractor@email.com

# Calendar integration
CALENDAR_TYPE=google
GOOGLE_CALENDAR_CREDENTIALS=path_to_credentials_json

# Server
PORT=3000